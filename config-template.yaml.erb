# ========================
# 基础运行参数
# ========================

# 混合端口，HTTP / SOCKS5 共用
mixed-port: <%= yaml_scalar(port) %>
# 是否允许局域网其他设备连接
allow-lan: true
# 运行模式，常用 rule
mode: rule
# 日志级别，可选 silent / error / warning / info / debug
log-level: info
# 是否启用 IPv6
ipv6: false
# 是否启用统一延迟计算，测速结果更稳定
unified-delay: true
# 是否并发建立 TCP 连接，通常建议开启
tcp-concurrent: true
# 是否启用 geodata 规则集
geodata-mode: true
# 进程匹配模式，strict 更稳妥
find-process-mode: strict
# TLS 指纹策略，random 可降低特征固定带来的风险
global-client-fingerprint: random
# 长连接保活间隔，单位秒
keep-alive-interval: 1800

# ========================
# 外部控制与面板
# ========================

# 外部控制地址，默认只监听本机
external-controller: <%= yaml_scalar(":#{web_port}") %>
# Web 面板目录
external-ui: "./Yacd-meta-gh-pages/"
# 面板/API 鉴权密码
secret: <%= yaml_scalar(web_secret) %>

profile:
  # 记住策略组选择
  store-selected: true
  # 记住 fake-ip 映射
  store-fake-ip: true

# ========================
# Geo 数据源
# ========================

geox-url:
  # GeoIP 数据
  geoip: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geoip.dat"
  # GeoSite 数据
  geosite: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geosite.dat"
  # 国家库 mmdb 数据
  mmdb: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/country.mmdb"

# ========================
# 域名嗅探
# ========================

sniffer:
  # 是否启用域名嗅探
  enable: true
  sniff:
    TLS:
      # 对 TLS 流量做嗅探的端口
      ports: [443, 8443]
    HTTP:
      # 对 HTTP 流量做嗅探的端口
      ports: [80, 8080-8880]
      # 用嗅探到的域名覆盖目标地址
      override-destination: true

# ========================
# TUN 模式
# ========================

tun:
  # 是否启用 TUN
  enable: true
  # TUN 协议栈，gvisor 兼容性较好
  stack: gvisor
  dns-hijack:
    # 劫持所有 UDP 53 请求
    - "any:53"
    # 劫持所有 TCP 53 请求
    - "tcp://any:53"
  # 自动添加路由
  auto-route: true
  # 自动识别出口网卡
  auto-detect-interface: true
  # TUN 设备名称
  device: <%= yaml_scalar(tun_device) %>
  # 是否启用严格路由
  strict-route: false
  # TUN MTU
  mtu: 1500
  # 禁用 ipv6
  inet6: false

# ========================
# DNS 设置
# ========================

dns:
  # 是否启用内置 DNS
  enable: true
  # DNS 是否启用 IPv6
  ipv6: false
  # 增强模式，fake-ip 适合大多数场景
  enhanced-mode: fake-ip
  # fake-ip 地址池范围
  fake-ip-range: 198.18.0.1/16

  # 仅用于解析下方 DoH/DoT 服务器自身域名的传统 DNS
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 1.1.1.1
    - 8.8.8.8

  # 主 DNS，优先使用国内低延迟解析器
  nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query

  # 直连请求二次解析使用的 DNS
  direct-nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query
<% if dns_split_cn_foreign -%>
  # 是否让 direct-nameserver 遵循 nameserver-policy
  direct-nameserver-follow-policy: true

  # 回退 DNS，优先使用境外解析器提高抗污染能力
  fallback:
    - https://1.1.1.1/dns-query
    - https://dns.google/dns-query
    - tls://8.8.4.4
    - tls://1.0.0.1

  # 开启后按国内外域名区分 DNS
  nameserver-policy:
    # 内网和中国域名优先走国内 DNS
    "geosite:private,cn":
      - https://doh.pub/dns-query
      - https://dns.alidns.com/dns-query
    "+.lan":
      - 223.5.5.5
    "+.local":
      - 223.5.5.5
    "+.arpa":
      - 223.5.5.5

  # 满足条件时优先采用 fallback 结果
  fallback-filter:
    # 对解析结果做 GeoIP 判断
    geoip: true
    # 以中国大陆为可信区域
    geoip-code: CN
    # 这些 geosite 命中时优先 fallback
    geosite:
      - gfw
    # 这些网段结果视为可疑
    ipcidr:
      - 240.0.0.0/4
    # 这些域名优先使用 fallback 结果
    domain:
      - "+.google.com"
      - "+.facebook.com"
      - "+.youtube.com"
      - "+.openai.com"
      - "+.chatgpt.com"
<% end -%>

  # 这些域名不走 fake-ip，避免兼容性问题
  fake-ip-filter:
    - "*.lan"
    - "*.localdomain"
    - "*.example"
    - "*.invalid"
