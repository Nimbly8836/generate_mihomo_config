# ========================
# 复用锚点
# ========================

# 通用策略组模板
pr: &pr
  # 手动选择类型
  type: select
  proxies:
    - default
    - hong_kong
    - taiwan
    - japan
    - singapore
    - united_states
    - other_regions
    - all_nodes
    - auto_select
    - private_vps
    - DIRECT

# 亚洲站点优先直连，不包含香港
direct_asia_no_hk_pr: &direct_asia_no_hk_pr
  type: select
  proxies:
    - DIRECT
    - taiwan
    - japan
    - singapore
    - other_regions

# 亚洲站点优先直连，包含香港
direct_asia_pr: &direct_asia_pr
  type: select
  proxies:
    - DIRECT
    - hong_kong
    - taiwan
    - japan
    - singapore
    - other_regions

# 订阅提供者的默认参数
provider_defaults: &provider_defaults
  # 从远端拉取订阅
  type: http
  # 订阅刷新间隔，单位秒
  interval: 3600
  health-check:
    # 是否启用健康检查
    enable: true
    # 健康检查地址
    url: "https://www.gstatic.com/generate_204"
    # 健康检查间隔，单位秒
    interval: 300

# 使用订阅节点的策略组默认参数
provider_use_defaults: &provider_use_defaults
  # 手动选择节点组
  type: select
<% if provider_names.empty? -%>
  # 当前未配置任何远程订阅
  use: []
<% else -%>
  # 使用 values 文件中定义的所有远程订阅
  use:
<% provider_names.each do |name| -%>
    - <%= name %>
<% end -%>
<% end -%>

# ========================
# 远程订阅
# ========================

proxy-providers:
<% if proxy_providers.empty? -%>
  # 没有远程订阅时保留空映射
  {}
<% else -%>
<% proxy_providers.each do |provider| -%>
  # 远程订阅：<%= provider.fetch("name") %>
  <%= provider.fetch("name") %>:
<% if provider_uses_defaults?(provider) -%>
    <<: *provider_defaults
<% end -%>
<%= render_hash(provider_body(provider), indent: 4) -%>
<% end -%>
<% end -%>

# ========================
# 规则集订阅
# ========================

rule-providers:
  # 广告域名规则集
  adblock_mihomo:
    type: http
    behavior: domain
    format: yaml
    url: "https://raw.githubusercontent.com/217heidai/adblockfilters/main/rules/adblockmihomo.yaml"
    path: "./rule_providers/adblock_mihomo.yaml"
    interval: 28800

# ========================
# 本地静态节点
# ========================

proxies:
<%= render_list(local_proxies, indent: 2) -%>

# ========================
# 策略组
# ========================

proxy-groups:
  # 全局默认出口
  - name: default
    type: select
    proxies:
      - DIRECT
      - hong_kong
      - taiwan
      - japan
      - singapore
      - united_states
      - other_regions
      - all_nodes
      - auto_select
      - private_vps

  # 本地静态节点入口，便于手动切换
  - name: local_proxy
    type: select
<% if local_proxy_names.empty? -%>
    proxies:
      - DIRECT
<% else -%>
    proxies:
<% local_proxy_names.each do |name| -%>
      - <%= name %>
<% end -%>
<% end -%>

  # 广告拦截动作
  - name: ad_block
    type: select
    proxies:
      - REJECT
      - DIRECT

  # 业务策略组
  - name: steam
    <<: *pr

  - name: apple
    <<: *direct_asia_no_hk_pr

  - name: google
    <<: *pr

  - name: openai
    type: select
    proxies:
      - taiwan
      - japan
      - singapore
      - united_states
      - other_regions

  - name: telegram
    <<: *pr

  - name: twitter
    <<: *pr

  - name: ehentai
    <<: *pr

  - name: bilibili
    <<: *direct_asia_pr

  - name: bilibili_sea
    <<: *pr

  - name: bahamut
    <<: *pr

  - name: youtube
    <<: *pr

  - name: netflix
    <<: *pr

  - name: spotify
    <<: *pr

  - name: github
    <<: *pr

  - name: domestic
    type: select
    proxies:
      - DIRECT
      - default
      - hong_kong
      - taiwan
      - japan
      - singapore
      - united_states
      - other_regions
      - all_nodes
      - auto_select

  - name: other
    <<: *pr

  # 按地区聚合的节点组
  - name: private_vps
    <<: *provider_use_defaults
    filter: "(?i)(_vps_).*"

  - name: hong_kong
    <<: *provider_use_defaults
    filter: "(?i)(🇭🇰|香港|港(?![澳台])|(^|[^a-z])(hk|hkg|hong[ _-]?kong)([^a-z]|$))"
    exclude-filter: "(?i)(澳門|澳门|macao|macau)"

  - name: taiwan
    <<: *provider_use_defaults
    filter: "(?i)(🇹🇼|台湾|(^|[^a-z])(tw|twn|tpe|taipei|taiwan)([^a-z]|$))"
    exclude-filter: "(?i)(hong[ _-]?kong|hk|hkg|macau|macao)"

  - name: japan
    <<: *provider_use_defaults
    filter: "(?i)(🇯🇵|日本|(^|[^a-z])(jp|jpn|japan|tokyo|osaka)([^a-z]|$))"

  - name: united_states
    <<: *provider_use_defaults
    filter: "(?i)(🇺🇸|美国|(^|[^a-z])(us|usa|united[ _-]?states|america)([^a-z]|$)|los[ _-]?angeles|san[ _-]?jose|silicon[ _-]?valley|new[ _-]?york|seattle|chicago)"
    exclude-filter: "(?i)(australia|au|aus)"

  - name: singapore
    <<: *provider_use_defaults
    filter: "(?i)(🇸🇬|新加坡|狮城|(^|[^a-z])(sg|sgp|singapore)([^a-z]|$))"

  - name: other_regions
    <<: *provider_use_defaults
    filter: ".+"
    exclude-filter: "(?i)(🇭🇰|🇹🇼|🇯🇵|🇺🇸|🇸🇬|🇨🇳|香港|台湾|日本|美国|新加坡|(^|[^a-z])(hk|hkg|hong[ _-]?kong|tw|twn|tpe|taipei|taiwan|jp|jpn|japan|us|usa|united[ _-]?states|america|sg|sgp|singapore)([^a-z]|$))"

  - name: all_nodes
    <<: *provider_use_defaults

  # 自动测速选择节点
  - name: auto_select
    type: url-test
    tolerance: 2
    proxies:
      - DIRECT
<% if provider_names.empty? -%>
    use: []
<% else -%>
    use:
<% provider_names.each do |name| -%>
      - <%= name %>
<% end -%>
<% end -%>

# ========================
# 规则
# ========================

rules:
  # values 文件中的自定义规则，优先级最高
<% local_rules.each do |rule| -%>
  - <%= rule %>
<% end -%>

  # SSH 相关流量始终直连
  - PROCESS-NAME,ssh,DIRECT
  - PROCESS-NAME,scp,DIRECT
  - PROCESS-NAME,sftp,DIRECT
  - PROCESS-NAME,rsync,DIRECT
  - DST-PORT,22,DIRECT

  # 广告过滤
  - RULE-SET,adblock_mihomo,ad_block

  # 站点分流
  - DOMAIN-SUFFIX,chatgpt.com,openai
  - DOMAIN-SUFFIX,oaistatic.com,openai
  - DOMAIN-SUFFIX,oaiusercontent.com,openai
  - DOMAIN-SUFFIX,openai.com,openai
  - DOMAIN-SUFFIX,openai.com.cdn.cloudflare.net,openai
  - DOMAIN-SUFFIX,openaiapi-site.azureedge.net,openai
  - DOMAIN-SUFFIX,openaicom-api-bdcpf8c6d2e9atf6.z01.azurefd.net,openai
  - DOMAIN-SUFFIX,openaicomproductionae4b.blob.core.windows.net,openai
  - DOMAIN-SUFFIX,production-openaicom-storage.azureedge.net,openai

  - GEOSITE,apple,apple
  - GEOSITE,apple-cn,apple
  - GEOSITE,steam,steam
  - GEOSITE,biliintl,bilibili_sea
  - GEOSITE,ehentai,ehentai
  - GEOSITE,github,github
  - GEOSITE,twitter,twitter
  - GEOSITE,youtube,youtube
  - GEOSITE,google,google
  - GEOSITE,google-cn,google
  - GEOSITE,telegram,telegram
  - GEOSITE,netflix,netflix
  - GEOSITE,bilibili,bilibili
  - GEOSITE,bahamut,bahamut
  - GEOSITE,spotify,spotify

  - GEOIP,google,google
  - GEOIP,netflix,netflix
  - GEOIP,telegram,telegram
  - GEOIP,twitter,twitter

  # 中国大陆流量优先直连
  - GEOSITE,CN,domestic
  - GEOIP,CN,domestic

  # 非中国大陆站点默认走全局代理，优先级放在兜底前
  - GEOSITE,geolocation-!cn,default

  # 其他流量走兜底策略
  - MATCH,other
